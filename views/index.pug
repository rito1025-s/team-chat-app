doctype html
html
  head
    title タスク進捗チャット
    style.
      body { font-family: sans-serif; display: flex; height: 100vh; margin: 0; }
      /* 画面を左右に分割 */
      .chat-section { flex: 1; border-right: 2px solid #ccc; display: flex; flex-direction: column; padding: 20px; }
      .task-section { width: 350px; background: #f9f9f9; padding: 20px; overflow-y: auto; }
      
      /* チャット表示エリア */
      .messages { flex: 1; overflow-y: auto; border: 1px solid #ddd; margin-bottom: 10px; padding: 10px; background: white; }
      .message { margin-bottom: 10px; padding-bottom: 5px; border-bottom: 1px dotted #ccc; }
      
      /* タスク表示エリア */
      .task-item { background: white; border: 1px solid #ddd; padding: 10px; margin-bottom: 10px; border-radius: 5px; }
      .status-badge { font-size: 0.8em; padding: 2px 5px; border-radius: 3px; color: white; }
      .status-未着手 { background: #888; }
      .status-進行中 { background: #007bff; }
      .status-完了 { background: #28a745; }
  body
    // 左側：チャット
    div.chat-section
      div(style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 10px;")
        h2(style="margin: 0;") 💬 チームチャット
        // ⬇︎ ログアウトボタンをここに復活させました！
        a(href="/logout" style="color: #dc3545; text-decoration: none; font-size: 0.9em; border: 1px solid #dc3545; padding: 5px 10px; border-radius: 4px;") ログアウト
      
      div.messages
        each msg in messages
          div.message
            strong #{msg.username}
            span : #{msg.content}
            div(style="font-size: 0.7em; color: #999;") #{msg.createdAt.toLocaleString()}
      
      form(action="/message" method="POST")
        input(type="text" name="content" placeholder="メッセージを入力..." required style="width: 70%; padding: 10px;")
        button(type="submit" style="padding: 10px;") 送信

    // 右側：タスク一覧
    div.task-section
      h2 📋 進捗管理
      form(action="/task" method="POST" style="margin-bottom: 20px;")
        input(type="text" name="title" placeholder="新しいタスク..." required style="width: 100%; margin-bottom: 5px;")
        button(type="submit" style="width: 100%;") タスク追加
      
      div.tasks
        each task in tasks
          div.task-item
            div(style="font-weight: bold;") #{task.title}
            div(style="font-size: 0.9em; margin: 5px 0;") 担当: #{task.username}
            span(class=`status-badge status-${task.status}`) #{task.status}
            // 状態更新ボタン
            form(action="/task/update" method="POST" style="margin-top: 10px; display: flex; gap: 5px;")
              input(type="hidden" name="id" value=task.id)
              select(name="status" style="font-size: 0.8em;")
                option(value="未着手" selected=task.status==="未着手") 未着手
                option(value="進行中" selected=task.status==="進行中") 進行中
                option(value="完了" selected=task.status==="完了") 完了
              button(type="submit" style="font-size: 0.8em;") 更新