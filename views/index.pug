doctype html
html(lang="ja")
  head
    meta(charset="UTF-8")
    title チームチャットルーム
    link(rel="stylesheet", href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css")
  body.bg-light
    // ナビゲーションバー
    nav.navbar.navbar-dark.bg-dark.shadow-sm
      .container-fluid
        span.navbar-brand.mb-0.h1 💬 チームチャット
        div
          span.text-light.me-3 こんにちは、#{username} さん
          a.btn.btn-outline-danger.btn-sm(href="/logout") ログアウト

    .container.mt-4(style="max-width: 800px;")
      // 📝 メッセージ投稿フォーム
      .card.mb-4.shadow-sm
        .card-body
          form(action="/message", method="POST")
            .input-group
              input.form-control(type="text", name="content", placeholder="メッセージを入力...", required=true, autofocus=true)
              button.btn.btn-primary(type="submit") 送信

      // 💬 メッセージ表示エリア
      .list-group.shadow-sm
        if messages.length === 0
          .list-group-item.text-center.text-muted.py-4 まだメッセージはありません。最初の発言をどうぞ！
        else
          each msg in messages
            .list-group-item.py-3
              .d-flex.w-100.justify-content-between
                h6.mb-1.fw-bold.text-primary #{msg.username}
                small.text-muted #{new Date(msg.createdAt).toLocaleString('ja-JP')}
              p.mb-1.text-dark.text-break #{msg.content}