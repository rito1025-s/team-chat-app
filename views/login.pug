doctype html
html(lang="ja")
  head
    meta(charset="UTF-8")
    title ログイン | チームチャット
    // 画面を綺麗にするためのスタイル（Bootstrap）を1行で導入
    link(rel="stylesheet", href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css")
  body.bg-light
    .container.mt-5(style="max-width: 400px;")
      .card.shadow-sm
        .card-body
          h2.card-title.text-center.mb-4 ログイン
          
          // エラーメッセージがあれば表示する
          if error
            .alert.alert-danger #{error}

          // HTMLのフォーム（POSTメソッドでデータを送信する）
          form(action="/login", method="POST")
            .mb-3
              label.form-label ユーザー名
              input.form-control(type="text", name="username", required=true)
            .mb-3
              label.form-label パスワード
              input.form-control(type="password", name="password", required=true)
            button.btn.btn-primary.w-100(type="submit") ログイン
          